# User and Group IDs to run boxwatchr as.
# Match this to your host user and group to avoid permission issues on mounted volumes.
PUID=99
PGID=100

# Internal port the web dashboard listens on. Defaults to 8143.
# If you change this, update your Docker port mapping to match.
WEB_PORT=8143

# Set your timezone for log timestamps. Changing this after log entries have already been created will cause your previous log entries to be out of order.
TZ=UTC

# Optional. If not set, a random password is generated at startup. Set this if you want a stable password for the rspamd web interface (port 11334).
RSPAMD_PASSWORD=

# Optional. Set to "true" if you are running boxwatchr behind an HTTPS reverse proxy.
# Marks the session cookie as Secure so it is only sent over encrypted connections.
# Leave unset or set to "false" for plain HTTP deployments.
SECURE_COOKIES=false